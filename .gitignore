.DS_Store
node_modules/
dist/
dist-renderer/
sample-out/
.vercel/
.codex/
.claude/
.omc/

# Local environment / secret files — workflows and scripts pull API
# tokens from these paths. Track only `.env.example`-style templates.
.env
.env.local
.env.*.local

# ncc emits .d.ts.map source maps with absolute paths baked in, so they
# differ byte-for-byte between local and CI. No runtime value for a
# bundled Action — keep them out of git to stabilize check:dist.
dist-action/*.d.ts.map
